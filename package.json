{
  "name": "javalsp",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "bugs": {
    "url": "https://github.com/nikeee/cappu/issues"
  },
  "license": "MIT",
  "author": "Niklas Mollenhauer <nikeee@outlook.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsdown",
    "ci": "oxlint --deny-warnings -f github",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "lsp": "tsx src/cli/main.ts lsp",
    "corpus:init": "git submodule update --init && for d in test-fixtures/emitter/corpus/*/; do git -C \"$d\" sparse-checkout set --no-cone '/**/*.java' '*.java'; done",
    "test": "tsx --test \"./src/**/*.test.ts\""
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "comment-json": "^5.0.0",
    "fast-xml-parser": "^5.8.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsdown/exe": "^0.22.2",
    "@types/cli-progress": "^3.11.6",
    "expect": "^30.4.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "testcontainers": "^12.0.2",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
