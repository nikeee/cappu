{
  "name": "javalsp",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Niklas Mollenhauer <nikeee@outlook.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsdown && node --run build:linux-x64 && node --run build:linux-arm64 && node --run build:darwin-x64 && node --run build:darwin-arm64 && node --run build:windows-x64",
    "build:linux-x64": "bun build ./src/cli/main.ts --outfile ./dist/linux-x64/cappu --bytecode --format=esm --compile --target=bun-linux-x64",
    "build:linux-arm64": "bun build ./src/cli/main.ts --outfile ./dist/linux-arm64/cappu --bytecode --format=esm --compile --target=bun-linux-arm64",
    "build:darwin-x64": "bun build ./src/cli/main.ts --outfile ./dist/darwin-x64/cappu --bytecode --format=esm --compile --target=bun-darwin-x64",
    "build:darwin-arm64": "bun build ./src/cli/main.ts --outfile ./dist/darwin-arm64/cappu --bytecode --format=esm --compile --target=bun-darwin-arm64",
    "build:windows-x64": "bun build ./src/cli/main.ts --outfile ./dist/windows-x64/cappu.exe --bytecode --format=esm --compile --target=bun-windows-x64",
    "build:native": "bun build ./src/cli/main.ts --outfile ./dist/native/cappu --bytecode --format=esm --compile",
    "ci": "oxlint --deny-warnings -f github",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "lsp": "tsx src/cli/main.ts lsp",
    "corpus:init": "git submodule update --init && for d in test-fixtures/emitter/corpus/*/; do git -C \"$d\" sparse-checkout set --no-cone '/**/*.java' '*.java'; done",
    "test": "tsx --test \"./src/**/*.test.ts\""
  },
  "dependencies": {
    "comment-json": "^5.0.0",
    "fast-xml-parser": "^5.8.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun": "^1.3.14",
    "expect": "^30.4.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
