{
  "name": "javalsp",
  "version": "0.1.4",
  "private": true,
  "description": "",
  "keywords": [],
  "bugs": {
    "url": "https://github.com/nikeee/cappu/issues"
  },
  "license": "MIT",
  "author": "Niklas Mollenhauer <nikeee@outlook.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsdown",
    "ci": "oxlint --deny-warnings -f github",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "version": "node scripts/sync-go-version.mjs && git add togo/internal/meta/meta.go",
    "lsp": "tsx src/cli/main.ts lsp",
    "corpus:init": "git submodule update --init && for d in test-fixtures/emitter/corpus/*/; do git -C \"$d\" sparse-checkout set --no-cone '/**/*.java' '*.java'; done",
    "format:corpus": "tsx --test ./src/format/format-corpus.test.ts",
    "test": "tsx --test \"./src/**/*.test.ts\""
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cli-progress": "^3.12.0",
    "comment-json": "^5.0.0",
    "fast-xml-parser": "^5.9.3",
    "p-limit": "^7.3.0",
    "vscode-languageserver": "^10.0.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsdown/exe": "^0.22.3",
    "@types/cli-progress": "^3.11.6",
    "expect": "^30.4.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "testcontainers": "^12.0.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
